# MongoDB (used by docker-compose for both services)
MONGO_ROOT_USERNAME=ebc_admin
MONGO_ROOT_PASSWORD=change_me_strong_password
MONGO_DB_NAME=e_business_card
MONGO_CARDS_COLLECTION=captured_cards

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# google/gemini-2.5-flash may be blocked in HK — use deepseek/deepseek-chat as fallback
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2
OPENROUTER_MAX_TOKENS=2048

# LLM guardrails (OCR prompt-injection protection)
OCR_TEXT_MAX_LENGTH=1500
OCR_TEXT_MAX_LINES=35
LLM_MAX_CUSTOM_FIELDS=30
LLM_MAX_FIELD_VALUE_LENGTH=500

# Per-user LLM rate limits (OpenRouter cost / abuse protection)
LLM_RATE_LIMIT_PER_HOUR=50
LLM_RATE_LIMIT_PER_DAY=100

# Firebase Admin — ONE service account per server (must match the mobile app's Firebase project):
#
#   | Where you run the API          | Copy template                    | FIREBASE_CREDENTIALS_PATH (source file) | JSON file (not in git)              |
#   |--------------------------------|----------------------------------|----------------------------------------|-------------------------------------|
#   | Local docker / your PC         | .env.example → .env              | ./firebase-service-account-dev.json    | mega-e-business-card-dev            |
#   | Cloud dev (focms :8001)        | deploy/.env.dev.example → .env   | ./firebase-service-account-dev.json    | mega-e-business-card-dev            |
#   | Production (ebc.megaannum.ai)  | deploy/.env.production.example   | ./firebase-service-account.json        | mega-e-business-card                |
#
# deploy/start.sh copies the source file into secrets/ for Docker (directory mount).
# Local docker without start.sh: mkdir -p secrets && cp firebase-service-account-dev.json secrets/firebase-service-account.json
#
FIREBASE_CREDENTIALS_PATH=./firebase-service-account-dev.json
# Public share link base for QR codes (no trailing slash). Local: http://localhost:8000/c
SHARE_PUBLIC_BASE_URL=http://localhost:8000/c
