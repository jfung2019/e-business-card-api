# Copy to the repo root on the cloud DEV server as .env
#   cp deploy/.env.dev.example .env
#
# Use with dev mobile builds (com.megaannumai.ebusinesscard.dev) and focms :8001.

DEPLOY_ENV=dev

MONGO_ROOT_USERNAME=ebc_admin
MONGO_ROOT_PASSWORD=change_me_use_a_long_random_password
MONGO_DB_NAME=e_business_card
MONGO_CARDS_COLLECTION=captured_cards

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2

FIREBASE_CREDENTIALS_PATH=./firebase-service-account-dev.json

SHARE_PUBLIC_BASE_URL=https://focms.megaannum.ai:8001/c
