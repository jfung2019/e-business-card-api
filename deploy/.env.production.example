# Copy to the repo root on the server as .env
#   cp deploy/.env.production.example .env

MONGO_ROOT_USERNAME=ebc_admin
MONGO_ROOT_PASSWORD=change_me_use_a_long_random_password
MONGO_DB_NAME=e_business_card
MONGO_CARDS_COLLECTION=captured_cards

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_RETRIES=2

# Relative FIREBASE_CREDENTIALS_PATH values are resolved to an absolute repo-root path in deploy/start.sh
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

SHARE_PUBLIC_BASE_URL=https://ebc.megaannum.ai/c
